# Backend Environment Variables for Render Deployment

# Server Port
PORT=5000

# MongoDB Connection String
# Use your MongoDB Atlas connection string from your cluster
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster

# JWT Secret for token signing (use a strong, random value)
JWT_SECRET=your_jwt_secret_key_change_this_to_random_value

# Environment
NODE_ENV=production

# CORS - Allowed Origins (update with your deployed frontend URL)
# For development: http://localhost:3000,http://localhost:5173
# For production: https://your-frontend-name.onrender.com
ALLOWED_ORIGINS=https://your-frontend-name.onrender.com

# Creator Secret - used for registering creator accounts
# Change this to a secure secret value
CREATOR_SECRET=your_creator_secret_key
